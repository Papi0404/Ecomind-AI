# ============================================================
#  EcoMind AI — Environment Variables Template
#  Copy this file to .env and fill in your actual values.
#  WARNING: Never commit real credentials to this file.
# ============================================================

# DATABASE (PostgreSQL — Supabase or local)
DATABASE_URL="postgresql://postgres:your-db-password@localhost:5432/ecomind?schema=public"

# SUPABASE STORAGE (for file uploads on Vercel serverless)
SUPABASE_URL="https://your-project-ref.supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# AUTHENTICATION
# Generate with: openssl rand -base64 48
JWT_SECRET="generate-a-long-random-secret-here"

# GOOGLE AI STUDIO (GEMINI API)
# Get your key at: https://aistudio.google.com/
GEMINI_API_KEY="your-gemini-api-key"
# Optional backup keys (comma-separated or separate vars):
# GEMINI_API_KEY_BACKUP1="your-backup-key-1"
# GEMINI_API_KEY_BACKUP2="your-backup-key-2"

# CACHE / SESSION (Upstash Redis — for production rate limiting)
# Create a free database at: https://console.upstash.com/redis
# After creating, copy values from the REST tab in the Connect section:
REDIS_URL="rediss://default:[UPSTASH_REDIS_REST_TOKEN]@[your-db-name].upstash.io:6379"
UPSTASH_REDIS_REST_URL="https://[your-db-name].upstash.io"
UPSTASH_REDIS_REST_TOKEN="[your-upstash-rest-token]"

# EMAIL VERIFICATION (SMTP — Gmail App Password or Resend)
# Leave empty for console/sandbox mode (OTP printed to server logs in dev only)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT=587
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-gmail-app-password"

# ADMIN PORTAL PATH SECRET
# Do NOT use NEXT_PUBLIC_ prefix — that would expose the path to the browser.
# Generate a random path: openssl rand -hex 16
ADMIN_SECRET_PATH="your-secret-admin-path"
